# ── Projektspezifisch ────────────────────────────────────────────────
# Interner Business Case: enthält Vertriebsstrategie, Budgets und
# Wirtschaftlichkeitsrechnung der Kundin. Das Repo ist öffentlich —
# das Dokument gehört nicht hinein.
AlpenDry_Business_Case.docx
*.docx

# Lokale Editor-/Agent-Einstellungen
.claude/settings.local.json

# Build-Artefakt
tsconfig.tsbuildinfo

# Logo-Quelldatei (Markenasset). Die abgeleitete, freigestellte Fassung
# liegt in public/brand/mark.png und wird ausgeliefert.
Logo.png

# Original-Fotos der Kundin (WhatsApp, unkomprimiert). Die optimierten
# WebP-Fassungen liegen in public/fotos/ und werden ausgeliefert — die
# Originale gehören nicht ins öffentliche Repo.
WhatsApp Image*.jpeg

# Bildquellen für /arbeiten. Ausgeliefert werden die 4:3-WebP in
# public/arbeiten/ (erzeugt mit sharp). Fünf davon sind lizenziertes
# Stockmaterial — Lizenzbelege liegen bei der Kundin, die Originale gehören
# nicht ins öffentliche Repo.
/Wasserschaden.jpg
/Leckageortung.webp
/Trocknung.webp
/Schimmel.webp
/Hochwasser.jpg
/Dokumentation.jpg
